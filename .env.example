NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Single-user auth — only this email may sign in
ALLOWED_EMAIL=you@example.com

# YouTube Data API v3 key — expands playlists into course lessons (Media).
# Free: console.cloud.google.com → enable "YouTube Data API v3" → create API key.
YOUTUBE_API_KEY=your-youtube-api-key
